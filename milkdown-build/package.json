  "type": "module",
  "scripts": {
    "build": "esbuild entry.js --bundle --format=iife --global-name=MilkdownBundle --minify --outfile=../static/vendor/milkdown.bundle.js --alias:katex=./katex-global.js"
  },
  "dependencies": {
    "@milkdown/core": "^7.5.6",
    "@milkdown/plugin-emoji": "^7.20.0",
