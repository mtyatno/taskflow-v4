    "@milkdown/plugin-indent": "^7.20.0",
    "@milkdown/plugin-listener": "^7.5.6",
    "@milkdown/plugin-math": "^7.5.9",
    "@milkdown/preset-commonmark": "^7.5.6",
    "@milkdown/preset-gfm": "^7.5.6",
    "@milkdown/prose": "^7.5.6",
    "@milkdown/utils": "^7.5.6"
  },
  "devDependencies": {
    "esbuild": "^0.21.0"
  }
}
