# ╔══════════════════════════════════════════════════════╗
# ║         TaskFlow V4 — Configuration                 ║
# ╚══════════════════════════════════════════════════════╝

# Telegram Bot Token (dapatkan dari @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed Telegram User IDs (comma-separated)
# Kosongkan untuk allow semua user
# Cara cek ID: kirim pesan ke @userinfobot
ALLOWED_USER_IDS=123456789

# Path database SQLite (default: ./taskflow.db)
DB_PATH=./taskflow.db

# Interval recalculate Eisenhower quadrant (menit)
EISENHOWER_INTERVAL_MINUTES=15

# Timezone
TIMEZONE=Asia/Jakarta
